            new Vertices(15, 173.091034656191, 213.908965343809),
            new Vertices(16, 164.288445856511, 210.70508503624),
            new Vertices(17, 156.175936136879, 206.021325365807)
        };

        totalVertices = V.length;

        for (int i = 0; i < totalVertices; i++) {
            vertices[i] = V[i];
        }

        // Inicialização do Array de Arestas
        Arestas[] A = {
            new Arestas(0, 2, 0),   new Arestas(2, 3, 0),   new Arestas(3, 4, 0),
            new Arestas(4, 5, 0),   new Arestas(5, 6, 0),   new Arestas(6, 7, 0),
            new Arestas(7, 8, 0),   new Arestas(8, 9, 0),   new Arestas(9, 0, 0),
            new Arestas(9, 10, 0),  new Arestas(10, 11, 0), new Arestas(11, 12, 0),
