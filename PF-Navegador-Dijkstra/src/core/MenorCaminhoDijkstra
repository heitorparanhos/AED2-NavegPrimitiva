import java.util.Scanner;

public class DijkstraGrafo {

    // Constantes equivalentes aos #define do C
    private static final int MAX_VERTICES = 18;
    private static final double INF = 1e9;

    // Structs convertidas em classes estáticas internas
    public static class Vertices {
        int id;
        double x;
        double y;

        // Construtor auxiliar para facilitar a inicialização semelhante ao C
        public Vertices(int id, double x, double y) {
            this.id = id;
            this.x = x;
            this.y = y;
        }
    }

    public static class Arestas {
        int orig;
        int dest;
        double dist;

        public Arestas(int orig, int dest, double dist) {
            this.orig = orig;
            this.dest = dest;
            this.dist = dist;
        }
    }

    // Variáveis globais mantidas conforme o código em C
    private static double[][] matrizAdj = new double[MAX_VERTICES][MAX_VERTICES];
    private static Vertices[] vertices = new Vertices[MAX_VERTICES];
    private static int totalVertices;
    private static int totalArestas;

    // Função para calcular a distância euclidiana
    public static double calcDist(double x0, double y0, double x1, double y1) {
        return Math.sqrt(Math.pow(x0 - x1, 2.0) + Math.pow(y0 - y1, 2.0));
    }

    // Constrói a matriz de adjacência do grafo
    public static void construirGrafo(Vertices[] nos, Arestas[] arestas) {
        for (int i = 0; i < totalVertices; i++) {
            for (int j = 0; j < totalVertices; j++) {
                matrizAdj[i][j] = INF;
            }
        }

        for (int i = 0; i < totalArestas; i++) {
            int a = arestas[i].orig;
            int b = arestas[i].dest;
            double dist = calcDist(vertices[a].x, vertices[a].y, vertices[b].x, vertices[b].y);
            matrizAdj[a][b] = dist;
            matrizAdj[b][a] = dist;
        }
    }

    // Algoritmo de Dijkstra para encontrar o menor caminho
    public static void dijkstra(int inicio, int fim) {
        double[] dist = new double[MAX_VERTICES];
        int[] prev = new int[MAX_VERTICES];
        int[] visited = new int[MAX_VERTICES];

        for (int i = 0; i < totalVertices; i++) {
            dist[i] = INF;
            prev[i] = -1;
            visited[i] = 0;
        }

        dist[inicio] = 0;

        for (int i = 0; i < totalVertices; i++) {
            int u = -1;
            double min = INF;
            for (int j = 0; j < totalVertices; j++) {
                if (visited[j] == 0 && dist[j] < min) {
                    u = j;
                    min = dist[j];
                }
            }

            if (u == -1) break;

            visited[u] = 1;

            for (int v = 0; v < totalVertices; v++) {
                if (matrizAdj[u][v] < INF && dist[u] + matrizAdj[u][v] < dist[v]) {
                    dist[v] = dist[u] + matrizAdj[u][v];
                    prev[v] = u;
                }
            }
        }

        if (dist[fim] == INF) {
            System.out.printf("Sem caminho entre %d e %d\n", inicio, fim);
            return;
        }

        System.out.printf("\nDistancia total: %.2f u. m.\n", dist[fim]);

        // Reconstrói o caminho
        int[] path = new int[MAX_VERTICES];
        int path_len = 0;
        for (int v = fim; v != -1; v = prev[v]) {
            path[path_len++] = v;
        }

        System.out.println("\nCaminho (do inicio ao fim):");
        for (int i = path_len - 1; i >= 0; i--) {
            int idx = path[i];
            System.out.printf("%d (x=%f, y=%f)\n", idx, vertices[idx].x, vertices[idx].y);
        }
    }

