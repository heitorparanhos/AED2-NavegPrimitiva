public class Vertice {
    public long id_original;
    public double lat;
    public double lon;
    public double x;
    public double y;
    public int id_interno; // de 0 a n-1

    // Construtor padrão (vazio) para manter a compatibilidade com a inicialização do array
    public Vertice() {
    }

    // Construtor auxiliar opcional, caso queira instanciar passando parâmetros diretamente
    public Vertice(long id_original, double lat, double lon, int id_interno) {
        this.id_original = id_original;
        this.lat = lat;
        this.lon = lon;
        this.id_interno = id_interno;
    }
}
