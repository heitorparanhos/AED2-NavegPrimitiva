public class Vertice {
    public long id_original;
    public double lat;
    public double lon;
    public double x;
    public double y;
    public int id_interno; 

    public Vertice() {
    }

    // Construtor usado pelo Dijkstra (id, x, y)
    public Vertice(int id_interno, double x, double y) {
        this.id_interno = id_interno;
        this.x = x;
        this.y = y;
    }
}
